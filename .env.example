# Okta Configuration
# Your Okta domain (e.g., dev-12345.okta.com)
OKTA_DOMAIN=dev-xxxxx.okta.com

# Okta API Token - Generate from Okta Admin Console:
# Security > API > Tokens > Create Token
OKTA_API_TOKEN=00xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MCP Server API Key - Required for authorization
# Clients must send this in the x-api-key header
MCP_API_KEY=your-secret-api-key-here

# Server port (Railway provides PORT automatically)
PORT=8000
